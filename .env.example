# ============================================================
# VulnFlow - 环境变量配置模板
# 复制此文件为 .env 并根据需要修改
#   cp .env.example .env
# ============================================================

# -------------------- 项目基础 --------------------
PROJECT_NAME=vulnflow
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
TIMEZONE=Asia/Shanghai

# -------------------- 安全密钥 --------------------
# 生成方式: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------- PostgreSQL --------------------
POSTGRES_USER=vulnflow
POSTGRES_PASSWORD=vulnflow_secret
POSTGRES_DB=vulnflow
POSTGRES_PORT=5432

# -------------------- Redis --------------------
REDIS_PASSWORD=
REDIS_PORT=6379

# -------------------- Elasticsearch --------------------
ELASTICSEARCH_PORT=9200

# -------------------- MinIO --------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vulnflow
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_SECURE=false

# -------------------- Qdrant --------------------
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334

# -------------------- AI / LLM --------------------
# 请填入你的 API Key（至少配置一个 LLM 供应商）
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5-20251001
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# -------------------- 工具集成 --------------------
# Nuclei 扫描器
NUCLEI_PATH=/usr/local/bin/nuclei
NUCLEI_TEMPLATES_PATH=/app/data/nuclei-templates

# Nmap
NMAP_PATH=/usr/bin/nmap

# SQLMap
SQLMAP_PATH=/usr/local/bin/sqlmap

# FFUF
FFUF_PATH=/usr/local/bin/ffuf

# -------------------- 邮件通知 --------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
ALERT_EMAIL=admin@vulnflow.local

# -------------------- Webhook 通知 --------------------
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
WECOM_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=

# -------------------- 前端 --------------------
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000/ws
FRONTEND_PORT=3000

# -------------------- 速率限制 --------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# -------------------- 备份 --------------------
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/workspace/vulnflow/backups

# -------------------- 监控 --------------------
SENTRY_DSN=
PROMETHEUS_ENABLED=false
